# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
# Кто может пользоваться ботом (id через запятую). Пусто = пускать всех.
ALLOWED_USER_IDS=123456789,987654321

# Распознавание голоса (Groq Whisper). Пусто = войсы отключены.
GROQ_API_KEY=gsk_...

# HTTP API. Пусто = API выключен.
API_KEY=change-me-secret
API_PORT=3000

# Путь к базе (опционально)
# DB_PATH=notes.db

# Logging Configuration
# LOG_LEVEL: debug, info, warn, error (default: info)
LOG_LEVEL=info
# LOG_TARGET: console, file, both (default: console)
LOG_TARGET=console
# LOG_FILE_PATH: path to write log files (default: logs/app.log)
LOG_FILE_PATH=logs/app.log
